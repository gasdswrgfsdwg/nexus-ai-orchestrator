# Google Gemini — gere uma chave em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua-chave-aqui

# OpenRouter — gere uma chave em https://openrouter.ai/keys
# Acessa 200+ modelos (GPT-4o, Claude, Llama, Mistral, etc.)
OPENROUTER_API_KEY=sk-or-v1-...
# Modelo padrão (opcional — padrão: openai/gpt-4o-mini)
# OPENROUTER_MODEL=anthropic/claude-3-haiku

# Porta do servidor (padrão: 3001)
# PORT=3001
